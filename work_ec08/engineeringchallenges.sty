% -----------------------------------------------------------------------------
% Professional running header and footer
% -----------------------------------------------------------------------------
\newcommand{\ECHeaderMark}{%
  \begin{tikzpicture}[baseline=-0.55ex,x=1pt,y=1pt]
    \draw[ECBlue,line width=.65pt] (0,0) circle (5.2);
    \draw[ECBlue,line width=.65pt] (0,0) circle (2.0);
    \foreach \a in {0,45,...,315}{\draw[ECBlue,line width=.65pt] (\a:5.2)--(\a:7.2);}
  \end{tikzpicture}%
}

\newcommand{\ECHeader}{%
  \begin{minipage}[b]{\textwidth}
    \sffamily\small
    \color{ECBlue}
    \ECHeaderMark\hspace{1.5mm}%
    {\bfseries\MakeUppercase{Engineering Challenges}}%
    \hfill
    {\itshape Version 4.0 -- July 2026}
    \par\vspace{1.5mm}
    \begin{tikzpicture}[x=1pt,y=1pt]
      \draw[ECBlue,line width=.75pt] (0,0)--(.47\textwidth,0)--(.49\textwidth,-2)--(\textwidth,-2);
      \fill[ECBlue] (\textwidth,-2) circle (1.5pt);
    \end{tikzpicture}
  \end{minipage}%
}

\newcommand{\ECFooter}{%
  \begin{minipage}[t]{\textwidth}
    \centering
    {\sffamily\scriptsize\itshape\color{ECBlue}%
      Mechanical Engineering -- Mechatronics -- Energy -- Industry\par}
    \vspace{1.2mm}
    \begin{tikzpicture}[x=1pt,y=1pt,baseline]
      \coordinate (L) at (0,0);
      \coordinate (R) at (\textwidth,0);
      \draw[ECBlue,line width=.75pt] (L)--(.43\textwidth,0);
      \draw[ECBlue,line width=.75pt] (.57\textwidth,0)--(R);
      \fill[ECBlue] (L) circle (1.4pt);
      \fill[ECBlue] (R) circle (1.4pt);
      \node[
        draw=ECBlue,
        fill=white,
        line width=.75pt,
        rounded corners=7pt,
        minimum width=18mm,
        minimum height=7mm,
        inner sep=0pt,
        text=ECBlue,
        font=\sffamily\bfseries\small
      ] at (.5\textwidth,0) {\thepage};
    \end{tikzpicture}
  \end{minipage}%
}

\pagestyle{fancy}
\fancyhf{}
\fancyhead[C]{\ECHeader}
\fancyfoot[C]{\ECFooter}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% Keep the same design on pages that LaTeX would normally typeset as "plain".
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyhead[C]{\ECHeader}
  \fancyfoot[C]{\ECFooter}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

\newcommand{\ECchapter}[4]{%
\clearpage
\begin{tcolorbox}[enhanced,boxrule=0pt,colback=#4,left=5mm,right=5mm,top=3mm,bottom=3mm,arc=1mm]
{\color{white}\sffamily\bfseries\fontsize{21}{23}\selectfont EC#1 -- #2}\\[-1mm]
{\color{white}\sffamily\large #3}
\end{tcolorbox}}

\newtcolorbox{engineeringnews}{enhanced,breakable,colback=ECLightOrange,colframe=ECOrange,title=\sffamily\bfseries Engineering News,boxrule=.8pt,arc=1mm}
\newtcolorbox{ecarticle}[1][Main Article]{enhanced,breakable,colback=white,colframe=ECBlue,title={\sffamily\bfseries #1},boxrule=.8pt,arc=1mm}
\newtcolorbox{engineeringfocus}{enhanced,breakable,colback=ECLightBlue,colframe=ECBlue,title=\sffamily\bfseries Engineering Focus,boxrule=.8pt,arc=1mm}
\newtcolorbox{vocabulary}{enhanced,breakable,colback=ECGrey,colframe=ECGreen,title=\sffamily\bfseries Useful Vocabulary,boxrule=.8pt,arc=1mm}
\newtcolorbox{keyfigures}{enhanced,breakable,colback=ECOrange!10,colframe=ECOrange,title=\sffamily\bfseries Key Figures,boxrule=.8pt,arc=1mm}
\newtcolorbox{speaking}{enhanced,breakable,colback=ECLightOrange,colframe=ECOrange,title=\sffamily\bfseries Speaking Task,boxrule=.8pt,arc=1mm}
\newtcolorbox{applicationexercise}{enhanced,breakable,colback=ECGreen!6,colframe=ECGreen,title=\sffamily\bfseries Application Exercise,boxrule=.8pt,arc=1mm,before skip=5pt,after skip=5pt}
\newtcolorbox{engineeringchallenge}{enhanced,breakable,colback=ECPurple!8,colframe=ECPurple,title=\sffamily\bfseries Engineering Challenge,boxrule=.8pt,arc=1mm}
\newtcolorbox{challenge}{enhanced,breakable,colback=ECLightBlue,colframe=ECGreen,title=\sffamily\bfseries Engineering Challenge,boxrule=.8pt,arc=1mm}
\newenvironment{questions}{\begin{tcolorbox}[enhanced,breakable,colback=white,colframe=ECBlue,title={\sffamily\bfseries Questions},boxrule=.8pt,arc=1mm]\begin{enumerate}[leftmargin=6mm,itemsep=1.2mm]}{\end{enumerate}\end{tcolorbox}}
\newcommand{\ECObjectives}[1]{\begin{tcolorbox}[colback=ECGrey,colframe=ECBlue,title=\sffamily\bfseries Learning Objectives,boxrule=.8pt]#1\end{tcolorbox}}
\newcommand{\ECplaceholder}[2]{\begin{tcolorbox}[colback=ECGrey,colframe=ECDarkGrey,boxrule=.5pt,arc=1mm,height=#2,valign=center,halign=center]{\sffamily\small #1}\end{tcolorbox}}
\newcommand{\ECsource}[2]{\par\footnotesize\textbf{#1:} \href{#2}{online resource}\par}
